{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YASGM",
  "version": "0.1.0",
  "identifier": "dev.yasgm.ui",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "npm run build:sidecar",
    "beforeBuildCommand": "npm run build:sidecar"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "YASGM",
        "width": 900,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/yasgm"],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": null
    }
  }
}
